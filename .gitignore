# ===== Kaizen MAX .gitignore =====

# ----- Secrets & Environment -----
.env
.env.local
.env.*.local
.venv/
*.pem
*.key
credentials.json
data/

# ----- Rust / core -----
core/target/
ui-rs/target/
ui-dioxus/target/
ui-tauri-solid/src-tauri/target/
ui-rust-native/target/
**/*.rs.bk

# ----- Node / UI -----
ui/node_modules/
ui/dist/
ui/.vite/
ui/.next/
ui-tauri-solid/node_modules/
ui-tauri-solid/dist/
ui-tauri-solid/.vite/
ui-rust-native/frontend/dist/
ui-rust-native/frontend/.trunk/
ui-rust-native/src-tauri/target/
ui-rust-native/frontend/target/
*.tsbuildinfo

# ----- OS -----
Thumbs.db
Desktop.ini
.DS_Store
*.swp
*.swo
*~

# ----- IDE -----
.vscode/
.idea/
*.code-workspace

# ----- Build artifacts -----
*.exe
*.dll
*.so
*.dylib

# ----- Logs -----
*.log
logs/

# ----- Local smoke/probe artifacts -----
tmp_*.png
core/*_body.json
core/*_health.json
core/codex_last.txt
core/health_body.txt
core/probe_*.json
core/smoke_*.json
core/v1_no_bearer_body.json
core/profiles/
nul

# ----- Scratch / tool config -----
