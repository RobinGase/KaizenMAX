{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kaizen MAX Mission Control",
  "version": "0.1.0",
  "identifier": "com.argtech.kaizenmax.missioncontrol",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Kaizen MAX Mission Control",
        "width": 1480,
        "height": 920,
        "resizable": true,
        "minWidth": 1160,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
