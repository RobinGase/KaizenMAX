# ===== Kaizen MAX Environment Configuration =====
# Copy this file to .env and fill in your values.
# Variables prefixed with ADMIN_ are governance-protected.

# ----- Provider Inference -----
# OpenAI / Anthropic / NVIDIA use env vars directly for inference.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# NVIDIA_API_KEY=
#
# Codex CLI can be the zeroclaw default without extra env vars:
# run `codex login` once and keep `codex` on PATH
#
# OpenClaw fallback can cover missing Zeroclaw tools when OpenClaw is installed:
# ZEROCLAW_OPENCLAW_FALLBACK_ENABLED=true
# ZEROCLAW_OPENCLAW_ALLOWED_TOOLS=sessions,browser,scheduler,health
# Optional override if openclaw is not on PATH:
# OPENCLAW_CLI_PATH=C:\Users\you\AppData\Roaming\npm\openclaw.cmd
#
# Gemini can use API key env vars:
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
#
# Or app-managed Google OAuth configured in Providers & Auth:
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_CLOUD_PROJECT=
# Optional overrides:
# KAIZEN_GEMINI_OAUTH_REDIRECT_URI=http://127.0.0.1:9100/api/oauth/gemini/callback
# KAIZEN_GEMINI_OAUTH_STORE_PATH=../data/oauth/gemini_tokens.json
KAIZEN_INFERENCE_PROVIDER=codex-cli
KAIZEN_INFERENCE_MODEL=gpt-5.4
KAIZEN_INFERENCE_MAX_TOKENS=4096
KAIZEN_INFERENCE_TEMPERATURE=0.7

# ----- Kaizen Core -----
KAIZEN_HOST=127.0.0.1
KAIZEN_PORT=9100
KAIZEN_MODE=native
# Options: native | remote
# Required only for remote mode:
# KAIZEN_REMOTE_SECURITY_ACK=I_UNDERSTAND_REMOTE_REQUIRES_TLS_MTLS_AUTH
# Legacy env aliases are still accepted for compatibility:
# ZEROCLAW_HOST, ZEROCLAW_PORT, ZEROCLAW_MODE, ZEROCLAW_REMOTE_SECURITY_ACK

# ----- UI Server -----
UI_PORT=3000

# ----- Crystal Ball / Mattermost -----
# Optional env fallback for Crystal Ball bridge.
# Preferred path: configure URL + Channel in Settings -> Providers & Auth and
# set MATTERMOST_TOKEN in the local environment before launch.
# MATTERMOST_URL=
# MATTERMOST_TOKEN=
# MATTERMOST_CHANNEL_ID=
# Optional fallback variable name (treated as channel ID):
CRYSTAL_BALL_CHANNEL=
CRYSTAL_BALL_ARCHIVE_PATH=../data/crystal_ball_events.jsonl
CRYSTAL_BALL_ARCHIVE_TTL_DAYS=30
CRYSTAL_BALL_ARCHIVE_HMAC_KEY=

# ----- CORS (comma-separated allowed origins) -----
KAIZEN_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,tauri://localhost,http://tauri.localhost,https://tauri.localhost

# ----- Admin / Governance -----
# Optional API guard for sensitive endpoints.
# If set, provide Authorization: Bearer <token> or x-admin-token.
ADMIN_API_TOKEN=
ADMIN_HARD_GATES_ENABLED=true
ADMIN_REQUIRE_HUMAN_SMOKE_TEST=true
ADMIN_MAX_SUBAGENTS=5
ADMIN_AUTO_SPAWN=false
ADMIN_PROVIDER_INFERENCE_ONLY=true
