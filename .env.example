# ===== Kaizen MAX Environment Configuration =====
# Copy this file to .env and fill in your values.
# Variables prefixed with ADMIN_ are governance-protected.

# ----- Provider Inference -----
# API keys are stored encrypted in the vault (PUT /api/secrets/anthropic or /api/secrets/openai).
# These env vars are NOT used for inference; they exist only for reference.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
KAIZEN_INFERENCE_PROVIDER=anthropic
KAIZEN_INFERENCE_MODEL=claude-sonnet-4-20250514
KAIZEN_INFERENCE_MAX_TOKENS=4096
KAIZEN_INFERENCE_TEMPERATURE=0.7

# ----- ZeroClaw Core -----
ZEROCLAW_HOST=127.0.0.1
ZEROCLAW_PORT=9100
ZEROCLAW_MODE=native
# Options: native | remote

# ----- UI Server -----
UI_PORT=3000

# ----- Crystal Ball / Mattermost -----
# Optional env fallback for Crystal Ball bridge.
# Preferred path: configure URL + Channel in Settings -> Providers and store token
# in encrypted Provider Credentials (Mattermost Bot).
# MATTERMOST_URL=
# MATTERMOST_TOKEN=
# MATTERMOST_CHANNEL_ID=
# Optional fallback variable name (treated as channel ID):
CRYSTAL_BALL_CHANNEL=
CRYSTAL_BALL_ARCHIVE_PATH=../data/crystal_ball_events.jsonl
CRYSTAL_BALL_ARCHIVE_TTL_DAYS=30
CRYSTAL_BALL_ARCHIVE_HMAC_KEY=

# ----- Secret Vault -----
# Optional manual override for the vault master key.
# If omitted, Kaizen MAX auto-generates and manages a key file on first run.
# ADMIN_VAULT_KEY=
# Optional managed key file path (auto-created when ADMIN_VAULT_KEY is not set)
KAIZEN_VAULT_KEY_PATH=../data/vault.key
KAIZEN_VAULT_PATH=../data/vault.json

# ----- CORS (comma-separated allowed origins) -----
KAIZEN_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ----- Admin / Governance -----
ADMIN_HARD_GATES_ENABLED=true
ADMIN_REQUIRE_HUMAN_SMOKE_TEST=true
ADMIN_MAX_SUBAGENTS=5
ADMIN_AUTO_SPAWN=false
ADMIN_PROVIDER_INFERENCE_ONLY=true
