# Copy to .env.vaultd.local and replace values.
KAIZEN_VAULTD_APP_TOKENS=kaizenmax=CHANGE_ME_LONG_RANDOM_TOKEN,externalapp=CHANGE_ME_LONG_RANDOM_TOKEN
KAIZEN_VAULTD_ADMIN_TOKEN=CHANGE_ME_ADMIN_TOKEN
KAIZEN_VAULTD_ADMIN_CROSS_APP_BYPASS=false

# Optional file-based secrets (preferred for production):
# KAIZEN_VAULTD_APP_TOKENS_FILE=./secrets/vaultd_app_tokens
# KAIZEN_VAULTD_ADMIN_TOKEN_FILE=./secrets/vaultd_admin_token
